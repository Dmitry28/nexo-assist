# Application
# NODE_ENV: technical runtime mode (development | production | test) — framework/tooling only.
NODE_ENV=development
# APP_ENV: deployment stage (development | staging | production | test) — drives app behavior.
# Defaults to test under jest, else development.
APP_ENV=development
PORT=3000

# API
API_PREFIX=api
API_VERSION=1

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*

# Logging: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Telegram bot (get a token from @BotFather). Bot stays disabled when unset.
# TELEGRAM_BOT_TOKEN=

# Daily subscription check (cron). Default 09:00 every day.
WATCH_CRON=0 9 * * *

# Pacing between subscription polls: base delay + random 0..jitter (ms).
WATCH_MIN_DELAY_MS=2000
WATCH_JITTER_MS=3000

# Database (Postgres). Defaults to the local docker DB (npm run db:up).
# In staging/prod set a Neon URL (SSL, pooled endpoint).
DATABASE_URL=postgres://app:app@localhost:5432/app

# Observability (OpenTelemetry) — tracing starts only when the endpoint is set.
# These are read natively by the OTel SDK (see src/tracing.ts).
# OTEL_SERVICE_NAME=nexo-assist
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
