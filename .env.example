# Application
NODE_ENV=development
PORT=3000

# API
API_PREFIX=api
API_VERSION=1

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*

# Logging: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Observability (OpenTelemetry) — tracing starts only when the endpoint is set.
# These are read natively by the OTel SDK (see src/tracing.ts).
# OTEL_SERVICE_NAME=nexo-assist
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
